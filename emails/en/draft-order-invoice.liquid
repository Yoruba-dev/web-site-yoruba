{% comment %}
  Pedro Yoruba Jewelry — Draft order invoice
  Paste into: Shopify Admin → Settings → Notifications → Customer notifications
  → Draft order invoice → Edit code (replace ALL the HTML body).
  Perfect for custom / made-to-order pieces quoted over WhatsApp.
{% endcomment %}
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Your invoice from Pedro Yoruba Jewelry</title>
</head>
<body style="margin:0; padding:0; background-color:#f3ede1;">
  <div style="display:none; max-height:0; overflow:hidden; mso-hide:all;">
    ✦ Your custom order invoice {{ name }} — review and pay securely.
  </div>

  <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="background-color:#f3ede1;">
    <tr><td align="center" style="padding:24px 12px;">

      <table role="presentation" width="600" cellpadding="0" cellspacing="0" style="width:600px; max-width:100%;">

        <!-- Black header with logo -->
        <tr><td align="center" style="background-color:#0d0a07; padding:30px 20px 22px;">
          <img src="https://pedrojewelryyoruba.com/assets/images/logo/pedro-yoruba-transparent.png" width="170" alt="Pedro Yoruba Jewelry" style="display:block; max-width:170px;">
          <p style="margin:12px 0 0; font-family:Georgia,'Times New Roman',serif; font-style:italic; font-size:13px; color:#cda557;">Donde la fe se lleva puesta</p>
        </td></tr>

        <!-- Orisha eleke stripe -->
        <tr><td>
          <table role="presentation" width="100%" cellpadding="0" cellspacing="0"><tr>
            <td height="5" width="14%" style="background-color:#f6efe2; font-size:0; line-height:0;">&nbsp;</td>
            <td height="5" width="14%" style="background-color:#cda557; font-size:0; line-height:0;">&nbsp;</td>
            <td height="5" width="14%" style="background-color:#c0392b; font-size:0; line-height:0;">&nbsp;</td>
            <td height="5" width="15%" style="background-color:#1f5fa8; font-size:0; line-height:0;">&nbsp;</td>
            <td height="5" width="14%" style="background-color:#2e7d4f; font-size:0; line-height:0;">&nbsp;</td>
            <td height="5" width="14%" style="background-color:#7b241c; font-size:0; line-height:0;">&nbsp;</td>
            <td height="5" width="15%" style="background-color:#000000; font-size:0; line-height:0;">&nbsp;</td>
          </tr></table>
        </td></tr>

        <!-- Body -->
        <tr><td style="background-color:#ffffff; padding:38px 40px 30px;">
          <p style="margin:0 0 6px; font-family:Georgia,serif; font-size:12px; letter-spacing:3px; text-transform:uppercase; color:#98662e;">Invoice {{ name }}</p>
          <h1 style="margin:0 0 16px; font-family:Georgia,'Times New Roman',serif; font-weight:normal; font-size:28px; color:#0d0a07;">Your custom piece, ready to order ✦</h1>
          <p style="margin:0 0 26px; font-family:Georgia,serif; font-size:15px; line-height:1.7; color:#4a4235;">
            {{ customer.first_name | default: "Hello" }}, as we discussed, here is the invoice
            for your piece. Review the details and complete your secure payment below —
            your order goes into the workshop the moment it's confirmed.
          </p>
          <table role="presentation" cellpadding="0" cellspacing="0" align="center" style="margin:0 auto 34px;"><tr>
            <td style="background-color:#cda557;">
              <a href="{{ invoice_url }}" target="_blank" style="display:inline-block; padding:14px 38px; font-family:Georgia,serif; font-size:13px; letter-spacing:2px; text-transform:uppercase; color:#0d0a07; text-decoration:none; font-weight:bold;">Review &amp; pay securely</a>
            </td>
          </tr></table>
          <table role="presentation" width="100%" cellpadding="0" cellspacing="0"><tr>
            <td height="1" style="background-color:#e8ddc6; font-size:0; line-height:0;">&nbsp;</td>
          </tr></table>
          <p style="margin:26px 0 14px; font-family:Georgia,serif; font-size:12px; letter-spacing:3px; text-transform:uppercase; color:#98662e;">Your pieces</p>
          {% for line in subtotal_line_items %}
          <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="margin-bottom:16px;"><tr>
            <td width="72" valign="top">
              {% if line.image %}
              <img src="{{ line.image | img_url: 'compact_cropped' }}" width="64" height="64" alt="{{ line.title }}" style="display:block; width:64px; height:64px; border:1px solid #e8ddc6;">
              {% endif %}
            </td>
            <td valign="middle" style="padding-left:14px;">
              <p style="margin:0; font-family:Georgia,serif; font-size:15px; color:#0d0a07;">{{ line.title }}</p>
              <p style="margin:4px 0 0; font-family:Georgia,serif; font-size:13px; color:#8a7d63;">Quantity: {{ line.quantity }}</p>
            </td>
            <td valign="middle" align="right" style="font-family:Georgia,serif; font-size:15px; color:#0d0a07; white-space:nowrap;">{{ line.final_line_price | money }}</td>
          </tr></table>
          {% endfor %}
          <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="margin-top:10px; border-top:1px solid #e8ddc6;">
            <tr>
              <td style="padding:14px 0 4px; font-family:Georgia,serif; font-size:14px; color:#8a7d63;">Subtotal</td>
              <td align="right" style="padding:14px 0 4px; font-family:Georgia,serif; font-size:14px; color:#0d0a07;">{{ subtotal_price | money }}</td>
            </tr>
            <tr>
              <td style="padding:12px 0 0; font-family:Georgia,serif; font-size:17px; color:#0d0a07; font-weight:bold; border-top:1px solid #e8ddc6;">Total</td>
              <td align="right" style="padding:12px 0 0; font-family:Georgia,serif; font-size:17px; color:#98662e; font-weight:bold; border-top:1px solid #e8ddc6;">{{ total_price | money }}</td>
            </tr>
          </table>
          <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="margin-top:30px; background-color:#faf6ec; border:1px solid #e8ddc6;"><tr>
            <td style="padding:16px 20px; font-family:Georgia,serif; font-size:13px; line-height:1.6; color:#4a4235;">
              ✦ &nbsp;<strong style="color:#98662e;">Made to order.</strong> Crafting time depends on the design — we'll keep you posted at every step, from casting to final polish. <strong style="color:#98662e;">Lifetime warranty.</strong> Every piece is handcrafted in our Miami workshop in 10k, 14k and 18k gold — and backed for life.
            </td>
          </tr></table>
        </td></tr>

        <!-- Black footer -->
        <tr><td style="background-color:#0d0a07; padding:30px 40px;" align="center">
          <p style="margin:0 0 6px; font-family:Georgia,serif; font-size:16px; color:#cda557;">Pedro Yoruba Jewelry</p>
          <p style="margin:0 0 14px; font-family:Georgia,serif; font-size:12px; line-height:1.7; color:#8a7d63;">
            11865 SW 26th St. c-41, Miami, FL 33175<br>
            Mon–Fri 10 AM–5 PM · Sat 10 AM–4 PM
          </p>
          <p style="margin:0 0 14px;">
            <a href="https://wa.me/13055228490" style="font-family:Georgia,serif; font-size:13px; color:#cda557; text-decoration:none;">WhatsApp (305) 522-8490</a>
          </p>
          <p style="margin:0; font-family:Georgia,serif; font-size:12px;">
            <a href="https://www.instagram.com/pedroyorubajewelry/" style="color:#8a7d63; text-decoration:none;">Instagram</a>
            &nbsp;·&nbsp;
            <a href="https://www.tiktok.com/@pedro_joyero_olofin" style="color:#8a7d63; text-decoration:none;">TikTok</a>
            &nbsp;·&nbsp;
            <a href="https://pedrojewelryyoruba.com" style="color:#8a7d63; text-decoration:none;">pedrojewelryyoruba.com</a>
          </p>
        </td></tr>

      </table>
    </td></tr>
  </table>
</body>
</html>
