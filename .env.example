# ---------------------------------------------------------------------------
# Shopify Storefront API (headless)
# Copy this file to `.env.local` and fill in your store's values, then restart
# the dev server. While these are empty, the site runs on the built-in demo
# catalogue and a demo checkout — nothing touches your real store.
#
# Where to get the token:
#   Shopify admin → Settings → Apps and sales channels → Develop apps →
#   Create an app → Configuration → Storefront API → enable the scopes
#   (read products, manage carts/checkout) → Install → API credentials →
#   copy the "Storefront API access token"  (NOT the Admin API token).
#
# These use NEXT_PUBLIC_ because the cart + checkout run in the browser. The
# Storefront token is a PUBLIC token by design (storefront/cart access only,
# never admin) — safe to expose client-side.
# ---------------------------------------------------------------------------

NEXT_PUBLIC_SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
NEXT_PUBLIC_SHOPIFY_STOREFRONT_ACCESS_TOKEN=your_storefront_api_token

# Public site URL (used for metadata / canonical links in production).
NEXT_PUBLIC_SITE_URL=http://localhost:3000
